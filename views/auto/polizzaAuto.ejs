<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Polizza Auto</title>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a> <!-- Adjust the href to point to the profile page -->
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6">
        <div class="text-center mb-4">
            <h1 class="my-4">Seleziona la polizza per il veicolo: <%= car_name %></h1>
        </div>
        <div class="container">
        <div class="row">
            <form action="polizzaAuto/opzioniaggiuntive" method="POST">
            <input type="hidden" name="user_id" value="<%= user.id %>">
            <input type="hidden" name="start_date" value="<%= start_date %>">
            <input type="hidden" name="end_date" value="<%= end_date %>">
            <input type="hidden" name="age" value="<%= age %>">
            <input type="hidden" id="car_name" name="car_name" value="<%= car_name %>">
            <!-- Assicurazione Base -->
            <div class="col-md mb-4">
                <div class="border p-4 rounded shadow-sm">
                    <div class="mb-3">
                        <h4>Assicurazione Base</h4>
                    </div>
                    <div class="mb-3">
                        €0 / giorno
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li>&#10060 Assistenza stradale</li>
                        <li>&#10060 Danni alla carrozzeria</li>
                        <li>&#10060 Danni agli pneumatici</li>
                        <li>&#10060 Danni ai cristalli</li>
                        <li>&#10060 Conducenti addizionali coperti gratuitamente</li>
                    </ul>
                    <button type="submit" name="insurance_type" value="Assicurazione Base" class="btn btn-light w-100">Seleziona Assicurazione Base</button>
                </div>
            </div>

            <!-- Full Protection -->
            <div class="col-md mb-4">
                <div class="border p-4 rounded shadow-sm">
                    <div class="mb-3">
                        <h4>Full Protection</h4>
                    </div>
                    <div class="mb-3">
                        €15 / giorno
                    </div>
                    <ul class="list-unstyled mb-4">
                        <li>&#9989 Assistenza stradale</li>
                        <li>&#9989 Danni alla carrozzeria</li>
                        <li>&#9989 Danni agli pneumatici</li>
                        <li>&#9989 Danni ai cristalli</li>
                        <li>&#9989 Conducenti addizionali coperti gratuitamente</li>
                    </ul>
                    <button type="submit" name="insurance_type" value="Assicurazione Full Protection" class="btn btn-primary w-100">Seleziona Assicurazione Full</button>
                </div>
            </div>
        </form>
        </div>
        </div>
    </div>
</body>
</html>
