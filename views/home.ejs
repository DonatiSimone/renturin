<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Home</title>
    <script src="/script/script.js"></script>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a> <!-- Adjust the href to point to the profile page -->
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="background-image-1 d-flex justify-content-center align-items-center vh-100">
        <div data-page="1" class="container text-center  p-4 rounded col-md-8 col-lg-6">
            <div class="container">
                <h1 class="my-4 text-white">"Scopri Torino senza confini con Renturin.<br><br>
                    Il tuo partner ideale per un noleggio auto senza pensieri.<br><br>
                    Con noi, ogni viaggio è un'avventura unica, e ogni strada è pronta a svelarti nuovi orizzonti."
                </h1>
            </div>
        </div>
    </div>
    <div class="container my-5 col-md-9 col-lg-8">
        <div class="card p-4 text-center">
            <h2>Ottieni offerte esclusive</h2>
            <h4 class="text-secondary">Iscriviti alla nostra newsletter</h4>
            <form action="/newsletter" method="POST" class="form-inline justify-content-center mt-3">
                <div class="form-group mb-3">
                    <input type="email" class="form-control" placeholder="Inserisci email" name="email" required>
                </div>
                <button type="submit" class="btn btn-warning ml-2">Iscriviti</button>
            </form>
        </div>
    </div>

    <div class="background-image-2 d-flex justify-content-center align-items-center vh-100">
        <div class="card custom-bg-color-4 text-white text-center p-4">
            <div class="card-body">
                <h2 class="card-title display-4 mb-4">Il noleggio giusto nella tua città</h2>
                <h3 class="card-text mb-4">L'agenzia di noleggio ideale per le tue necessità a Torino</h3>
                <a href="/auto" class="btn btn-light btn-lg mt-3">Trova il tuo veicolo ideale</a>
            </div>
        </div>
    </div>

    <div class="container my-5 text-center text-white">
        <h2 class="display-4 mb-3">Scopri i nostri veicoli</h2>
        <h4>Abbiamo tutte le alternative desiderabili, scoprile qui sotto:</h4>
    </div>

    <div class="slideshow-container container text-white">
        <div class="mySlides">
            <div class="text-center">
                <img src="/images/tesla_model_3.png" class="img-fluid" alt="Veicoli elettrici">
                <h3 class="mt-2">Veicoli elettrici</h3>
            </div>
        </div>

        <div class="mySlides">
            <div class="text-center">
                <img src="/images/ford-kuga.png" class="img-fluid" alt="Auto">
                <h3 class="mt-2">Auto</h3>
            </div>
        </div>

        <div class="mySlides">
            <div class="text-center">
                <img src="/images/Fleet_MPV.png" class="img-fluid" alt="Minivan">
                <h3 class="mt-2">Minivan</h3>
            </div>
        </div>

        <div class="mySlides">
            <div class="text-center">
                <img src="/images/Fleet_Van.png" class="img-fluid" alt="Furgoni">
                <h3 class="mt-2">Furgoni</h3>
            </div>
        </div>

        <div class="mySlides">
            <div class="text-center">
                <img src="/images/liberty.png" class="img-fluid" alt="Moto">
                <h3 class="mt-2">Moto</h3>
            </div>
        </div>

        <!-- Next and previous buttons -->
        <a class="prev" onclick="plusSlides(-1)">&#10094;</a>
        <a class="next" onclick="plusSlides(1)">&#10095;</a>
    </div>
    <br>

    <!-- The dots/circles -->
    <div class="text-center mb-4">
        <span class="dot" onclick="currentSlide(1)"></span>
        <span class="dot" onclick="currentSlide(2)"></span>
        <span class="dot" onclick="currentSlide(3)"></span>
        <span class="dot" onclick="currentSlide(4)"></span>
        <span class="dot" onclick="currentSlide(5)"></span>
    </div>

    <footer class="custom-bg-color-2 py-4">
        <div class="container">
            <div class="row">
                <div class="col">
                    <a href="/auto" class="text-white">Auto</a>
                </div>
                <div class="col">
                    <a href="/furgoni" class="text-white">Furgoni</a>
                </div>
                <div class="col">
                    <a href="/moto" class="text-white">Moto</a>
                </div>
                <div class="col">
                    <a href="/chisiamo" class="text-white">Chi siamo</a>
                </div>
                <div class="col">
                    <a href="/privacy" class="text-white">Privacy e sicurezza</a>
                </div>
            </div>
        </div>
    </footer>

    <footer class="custom-bg-color-3 text-center py-3">
        <p class="color-white mb-0">© 2024 Renturin. Tutti i diritti riservati.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
