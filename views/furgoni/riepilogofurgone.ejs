<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Riepilogo Noleggio Furgone</title>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a>
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6 align-items-center text-center">
        <div class="text-center mb-4">
            <h1>Riepilogo del tuo noleggio</h1>
        </div>

        <div class="furgone-image">
            <img src="<%= furgone_image %>" alt="<%= furgone_name %>" class="img-fluid">
        </div>

        <div class="mb-4">
            <h4>Veicolo Selezionato:</h4>
            <p><strong>Nome veicolo:</strong> <%= furgone_name %></p>
        </div>

        <div class="mb-4">
            <h4>Polizza Assicurativa:</h4>
            <p><strong>Tipo:</strong> <%= insurance_type %></p>
            <% if (insurance_type === 'Assicurazione Full Protection') { %>
                <p><strong>Costo:</strong> €15 / giorno</p>
            <% } else { %>
                <p><strong>Costo:</strong> €0 / giorno</p>
            <% } %>
        </div>

        <div class="mb-4">
            <h4>Opzioni Aggiuntive:</h4>
            <p><strong>Navetta:</strong> <%= has_navetta ? 'Sì' : 'No' %></p>
            <p><strong>Secondo Conducente:</strong> <%= has_secondo_conducente ? 'Sì' : 'No' %></p>
            <p><strong>Seggiolino:</strong> <%= has_seggiolino ? 'Sì' : 'No' %></p>
        </div>

        <div class="mb-5">
            <h4>Periodo di Noleggio:</h4>
            <p><strong>Data Inizio:</strong> <%= start_date %></p>
            <p><strong>Data Fine:</strong> <%= end_date %></p>
        </div>

        <div class="mb-5">
            <h2>Prezzo totale:</h2>
            <h2>€<%= finalPrice %></h2>
        </div>

        <div class="text-center">
            <form action="riepilogofurgone/confermaNoleggioFurgone" method="POST">
                <input type="hidden" name="user_id" value="<%= user.id %>">
                <input type="hidden" name="furgone_name" value="<%= furgone_name %>">
                <input type="hidden" name="insurance_type" value="<%= insurance_type %>">
                <input type="hidden" name="has_navetta" value="<%= has_navetta %>">
                <input type="hidden" name="has_secondo_conducente" value="<%= has_secondo_conducente %>">
                <input type="hidden" name="has_seggiolino" value="<%= has_seggiolino %>">
                <input type="hidden" name="start_date" value="<%= start_date %>">
                <input type="hidden" name="end_date" value="<%= end_date %>">
                <input type="hidden" name="age" value="<%= age %>">
                <input type="hidden" name="price" value="<%= finalPrice %>">
                <button type="submit" class="btn btn-primary w-100">Conferma e Invia Richiesta</button>
            </form>
        </div>
    </div>
</body>
</html>
