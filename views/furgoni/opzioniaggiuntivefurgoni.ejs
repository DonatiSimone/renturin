<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Opzioni Aggiuntive Furgone</title>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a> <!-- Adjust the href to point to the profile page -->
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6">
        <div class="text-center mb-4">
            <h1>Opzioni aggiuntive</h1>
        </div>
        <form action="opzioniaggiuntivefurgoni/riepilogofurgone" method="POST">
        <input type="hidden" name="user_id" value="<%= user.id %>">
        <input type="hidden" name="start_date" value="<%= start_date %>">
        <input type="hidden" name="end_date" value="<%= end_date %>">
        <input type="hidden" name="age" value="<%= age %>">
        <input type="hidden" id="furgone_name" name="furgone_name" value="<%= furgone_name %>">
        <input type="hidden" id="furgone_name" name="insurance_type" value="<%= insurance_type %>">
        <div class="d-flex flex-column align-items-center">
            <div class="furgone-image">
                <img src="<%= furgone_image %>" alt="<%= furgone_name %>" class="img-fluid">
            </div>
            <div class="form-group mb-3">
                <label><input type="checkbox" name="has_navetta" value="true"> Navetta - €15</label>
            </div>
            <div class="form-group mb-3">
                <label><input type="checkbox" name="has_secondo_conducente" value="true"> Secondo Conducente - €40</label>
            </div>
            <div class="form-group mb-4">
                <label><input type="checkbox" name="has_seggiolino" value="true"> Seggiolino - €20</label>
            </div>
            <button type="submit" class="btn btn-primary">Conferma</button>
            </form>
        </div>
    </form>
    </div>
</body>
</html>
