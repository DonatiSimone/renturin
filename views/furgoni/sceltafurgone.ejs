<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Scelta Furgone</title>
    <script src="/script/script.js"></script>


</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a> <!-- Adjust the href to point to the profile page -->
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="container my-5">
        <div class="text-center mb-4 text-white">
            <h1>Scegli il tuo veicolo</h1>
        </div>
        <div class="text-center mb-4 text-white">
            <h1>Da <%= start_date %> a <%= end_date %></h1>
        </div>
        <form action="sceltafurgone/polizzafurgone" method="POST">
        <input type="hidden" name="user_id" value="<%= user.id %>">
        <input type="hidden" name="start_date" value="<%= start_date %>">
        <input type="hidden" name="end_date" value="<%= end_date %>">
        <input type="hidden" name="age" value="<%= age %>">
        <input type="hidden" id="furgone_name" name="furgone_name" value="">
        <div class="row">

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 d-flex flex-column">
                    <img src="/images/Ford Transit.png" class="card-img-top img-fluid p-2" alt="Ford Transit">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h2 class="card-title">Ford Transit</h2>
                            <p>- Chilometraggio illimitato</p>
                            <p>- Pacchetto assicurazione base incluso</p>
                        </div>
                        <div class="text-center mt-4">
                            <p class="font-2">a partire da</p>
                            <p class="price-style"><b>€75</b> / al giorno</p>
                            <button type="submit" class="btn btn-primary" onclick="selectFurgone('Ford Transit')">Seleziona</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 d-flex flex-column">
                    <img src="/images/Ford Transit Box.png" class="card-img-top img-fluid p-2" alt="Ford Transit Box">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h2 class="card-title">Ford Transit Box</h2>
                            <p>- Chilometraggio illimitato</p>
                            <p>- Pacchetto assicurazione base incluso</p>
                        </div>
                        <div class="text-center mt-4">
                            <p class="font-2">a partire da</p>
                            <p class="price-style"><b>€60</b> / al giorno</p>

                            <button type="submit" class="btn btn-primary" onclick="selectFurgone('Ford Transit Box')">Seleziona</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 d-flex flex-column">
                    <img src="/images/Ford Ranger.png" class="card-img-top img-fluid p-2" alt="Ford Ranger">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h2 class="card-title">Ford Ranger</h2>
                            <p>- Chilometraggio illimitato</p>
                            <p>- Pacchetto assicurazione base incluso</p>
                        </div>
                        <div class="text-center mt-4">
                            <p class="font-2">a partire da</p>
                            <p class="price-style"><b>€60</b> / al giorno</p>
                            <button type="submit" class="btn btn-primary" onclick="selectFurgone('Ford Ranger')">Seleziona</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 border-0 d-flex flex-column">
                    <img src="/images/Fiat Doblo.png" class="card-img-top img-fluid p-2" alt="Fiat Doblo">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h2 class="card-title">Fiat Doblo</h2>
                            <p>- Chilometraggio illimitato</p>
                            <p>- Pacchetto assicurazione base incluso</p>
                        </div>
                        <div class="text-center mt-4">
                            <p class="font-2">a partire da</p>
                            <p class="price-style"><b>€70</b> / al giorno</p>
                            <button type="submit" class="btn btn-primary" onclick="selectFurgone('Fiat Doblo')">Seleziona</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>


</body>
</html>
