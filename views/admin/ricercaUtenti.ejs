<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <link rel="stylesheet" href="/css/table.css">
    <title>Ricerca Utente</title>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href=""><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/admin">Noleggi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/logout">Logout</a>
                    </li>
                </ul>
            </div>
            <span class="nav-item">
                <a class="nav-link custom-color-white pt-2" href="">Benvenuto Admin</a>
            </span>
        </div>
    </nav>

    <div class="container my-5 bg-white p-4 rounded">
        <h1 class="mb-4">Cerca Utente</h1>

        <form method="GET" action="/admin/ricercaUtenti" class="mb-4">
            <div class="input-group">
                <input type="text" name="user_id" class="form-control" placeholder="Inserisci ID Utente" required>
                <button type="submit" class="btn btn-primary">Cerca Utente</button>
            </div>
        </form>

        <% if (message) { %>
            <div class="alert alert-danger" role="alert">
                <%= message %>
            </div>
        <% } %>

        <% if (user) { %>
            <h2>Dettagli Utente</h2>
            <div class="table-container">
                <table class="table table-bordered">
                    <tr>
                        <th>ID</th>
                        <td><%= user.id %></td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td><%= user.email %></td>
                    </tr>
                    <tr>
                        <th>Nome</th>
                        <td><%= user.first_name %></td>
                    </tr>
                    <tr>
                        <th>Cognome</th>
                        <td><%= user.surname %></td>
                    </tr>
                    <tr>
                        <th>Telefono</th>
                        <td><%= user.phone_number %></td>
                    </tr>
                    <tr>
                        <th>Ruolo</th>
                        <td><%= user.role %></td>
                    </tr>
                    <tr></tr>
                        <th>Data di nascita</th>
                        <td><%= user.birth_year + '-' + user.birth_month + '-' + user.birth_day %> %></td>
                    </tr>
                </table>
            </div>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
