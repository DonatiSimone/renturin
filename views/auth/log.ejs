<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Log in</title>
    <style>
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>
            </div>
            <span class="nav-item">
                <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6">
        <form action="/log" method="POST">
            <div class="text-center mb-4">
                <h3>Log in</h3>
                <% if (message) { %>
                    <div class="alert alert-danger" role="alert">
                        <%= message %>
                    </div>
                    <% } %>
            </div>
            <div>
                <div class="mb-3">
                    <label for="email" class="form-label">La tua email</label>
                    <input type="email" class="form-control" id="email" placeholder="Enter Email" name="email" required>
                </div>

                <div class="mb-3">
                    <label for="pswrd" class="form-label">La tua password</label>
                    <input type="password" class="form-control" id="pswrd" placeholder="Enter Password" name="user_password" required>
                </div>

                <!-- subcontainer for the checkbox and forgot password link -->
                <!-- <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="remember" checked="checked" name="remember">
                        <label class="form-check-label" for="remember">Ricordami</label>
                    </div>
                    <p class="mb-0"><a href="#" class="text-decoration-none">Password dimenticata?</a></p>
                </div> -->

                <button type="submit" class="btn btn-primary w-100">Login</button>

                <div class="text-center mt-4">
                    <p class="mb-1">Non sei registrato? <a href="/registrati" class="text-decoration-none">Registrati qui!</a></p>
                </div>
            </div>
        </form>
    </div>

    <footer class="custom-bg-color-2 py-4 mt-auto">
        <div class="container">
            <div class="row">
                <div class="col">
                    <a href="/auto" class="text-white">Auto</a>
                </div>
                <div class="col">
                    <a href="/furgoni" class="text-white">Furgoni</a>
                </div>
                <div class="col">
                    <a href="/moto" class="text-white">Moto</a>
                </div>
                <div class="col">
                    <a href="/chisiamo" class="text-white">Chi siamo</a>
                </div>
                <div class="col">
                    <a href="/privacy" class="text-white">Privacy e sicurezza</a>
                </div>
            </div>
        </div>
    </footer>

    <footer class="custom-bg-color-3 text-center py-3">
        <p class="color-white mb-0">© 2024 Renturin. Tutti i diritti riservati.</p>
    </footer>
</body>
</html>
