<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Registrati</title>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6">
        <form action="/registrati/register" method="post">
            <div class="text-center mb-5">
                <h3>Registrati</h3>
            </div>

            <% if (errorMessage) { %>
                <div class="alert alert-danger" role="alert">
                    <%= errorMessage %>
                </div>
            <% } %>

            <div class="mb-3">
                <input type="text" class="form-control" placeholder="Nome" name="first_name" required>
            </div>

            <div class="mb-3">
                <input type="text" class="form-control" placeholder="Cognome" name="surname" required>
            </div>

            <div class="mb-3">
                <input type="email" class="form-control" placeholder="Email" name="email" required>
            </div>

            <div class="mb-3">
                <input type="password" class="form-control" placeholder="Password" name="user_password" required>
            </div>

            <div class="mb-3">
                <select class="form-select" name="prefix" id="prefix">
                    <% for (let row of rows) { %>
                        <option value="<%= row.id %>"><%= row.country %> (<%= row.prefix %>)</option>
                    <% } %>
                </select>
            </div>

            <div class="mb-4">
                <input type="text" class="form-control" placeholder="Cellulare" name="phone_number" required>
            </div>

            <div class="mb-4">
                <label class="form-label">Data di Nascita</label>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control" placeholder="Anno" name="birth_year" required>
                    <input type="text" class="form-control" placeholder="Mese" name="birth_month" required>
                    <input type="text" class="form-control" placeholder="Giorno" name="birth_day" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Info Patente</label>
                <input type="text" class="form-control mb-2" placeholder="Numero di Patente" name="driver_license_number" required>
                <input type="text" class="form-control mb-2" placeholder="Paese/Regione di Emissione" name="driver_license_country" required>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control" placeholder="Anno" name="driver_license_year" required>
                    <input type="text" class="form-control" placeholder="Mese" name="driver_license_month" required>
                    <input type="text" class="form-control" placeholder="Giorno" name="driver_license_day" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Info Carta Identità</label>
                <input type="text" class="form-control mb-2" placeholder="Numero Carta Identità" name="id_card_number" required>
                <input type="text" class="form-control mb-2" placeholder="Paese/Regione di Emissione" name="id_card_country" required>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control" placeholder="Anno" name="id_card_year" required>
                    <input type="text" class="form-control" placeholder="Mese" name="id_card_month" required>
                    <input type="text" class="form-control" placeholder="Giorno" name="id_card_day" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Info Carta di Credito</label>
                <input type="text" class="form-control mb-2" placeholder="Numero Carta di Credito" name="credit_card_number" required>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control" placeholder="Mese" name="credit_card_month" required>
                    <input type="text" class="form-control" placeholder="Anno" name="credit_card_year" required>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Indirizzo di Fatturazione</label>
                <input type="text" class="form-control mb-2" placeholder="Indirizzo" name="billing_address" required>
                <input type="text" class="form-control mb-2" placeholder="Città" name="billing_address_city" required>
                <input type="text" class="form-control mb-2" placeholder="Paese/Regione" name="billing_address_country" required>
                <input type="text" class="form-control mb-2" placeholder="Codice Postale" name="zip_code" required>
            </div>

            <div class="mb-4">
                <div class="form-check mt-2 mb-4">
                    <input type="checkbox" class="form-check-input" id="promotions" name="email_consent" checked="checked">
                    <label class="form-check-label" for="promotions">Sì, desidero ricevere e-mail promozionali da Renturin.</label>
                </div>
                <div>
                    Cliccando "Registrati" accetti i nostri <a href="/terminiecondizioni">termini e condizioni </a>
                </div>
            </div>

            <div class="mb-4">
                <button class="btn btn-primary w-100" type="submit">Registrati</button>
            </div>
        </form>
    </div>
</body>
</html>
