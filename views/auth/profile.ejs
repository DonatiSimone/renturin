<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Profile</title>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a href="/profile/prenotazioni" class="nav-link custom-color-white" href="">Prenotazioni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/logout">Logout</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    <form action="/profile" method="POST">
    <div class="container my-5 p-4 border rounded shadow-sm bg-white col-md-8 col-lg-6">
        <div class="d-flex mb-5">
            <h3 class="">Profilo Utente</h3>
            <button type="submit" class="ms-auto btn btn-primary btn-sm">Aggiorna Profilo</button>
        </div>
        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input type="text" class="form-control bg-light" id="first_name" name="first_name" value="<%= user.first_name %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Cognome</label>
            <input type="text" class="form-control bg-light" id="surname" name="surname" value="<%= user.surname %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control bg-light" id="email" name="email" value="<%= user.email %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Prefisso</label>
            <input type="text" class="form-control" value="<%= "+" %><%= user.prefix %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Numero di Telefono</label>
            <input type="text" class="form-control bg-light" id="phone_number" name="phone_number" value="<%= user.phone_number %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Data di Nascita</label>
            <input type="text" class="form-control" value="<%= user.birth_year + '-' + user.birth_month + '-' + user.birth_day %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Numero Patente</label>
            <input type="text" class="form-control" value="<%= user.driver_license_number %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Paese/Regione di Emissione Patente</label>
            <input type="text" class="form-control" value="<%= user.driver_license_country %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Data di Emissione Patente</label>
            <input type="text" class="form-control" value="<%= user.driver_license_year + '-' + user.driver_license_month + '-' + user.driver_license_day %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Numero Carta Identità</label>
            <input type="text" class="form-control" value="<%= user.id_card_number %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Paese/Regione di Emissione Carta Identità</label>
            <input type="text" class="form-control" value="<%= user.id_card_country %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Data di Emissione Carta Identità</label>
            <input type="text" class="form-control" value="<%= user.id_card_year + '-' + user.id_card_month + '-' + user.id_card_day %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Numero Carta di Credito</label>
            <input type="text" class="form-control" value="<%= user.credit_card_number %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Data di Scadenza Carta di Credito</label>
            <input type="text" class="form-control" value="<%= user.credit_card_year + '-' + user.credit_card_month %>" readonly>
        </div>

        <div class="mb-3">
            <label class="form-label">Indirizzo di Fatturazione</label>
            <input type="text" class="form-control bg-light" id="billing_address" name="billing_address" value="<%= user.billing_address %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Città di Fatturazione</label>
            <input type="text" class="form-control bg-light" id="billing_address_city" name="billing_address_city" value="<%= user.billing_address_city %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Paese/Regione di Fatturazione</label>
            <input type="text" class="form-control bg-light" id="billing_address_country" name="billing_address_country" value="<%= user.billing_address_country %>">
        </div>

        <div class="mb-3">
            <label class="form-label">Codice Postale</label>
            <input type="text" class="form-control bg-light" id="zip_code" name="zip_code" value="<%= user.zip_code %>">
        </div>
    </div>
    </form>
</body>
</html>
