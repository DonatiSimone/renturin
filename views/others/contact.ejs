<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/custom.css">
    <title>Contattaci</title>
    <style>
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top text-white custom-bg-color-2">
        <div class="container ">
            <a class="navbar-brand" href="/"><img src="/images/logo.png" alt="Renturin Logo" width="60" height="60"></a>
            <a class="navbar-brand custom-font text-white" href="/">Renturin</a>
            <button class="navbar-toggler color-white" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon "></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ml-auto pt-2">
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/auto">Noleggio auto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/furgoni">Noleggio furgoni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/moto">Noleggio Moto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link custom-color-white" href="/contact">Contattaci</a>
                    </li>
                </ul>

            </div>
            <span class="nav-item">
                <% if (user) { %>
                    <a class="nav-link custom-color-white pt-2" href="/profile"><%= "Benvenuto " %><%= user.first_name %></a> <!-- Adjust the href to point to the profile page -->
                <% } else { %>
                    <a class="nav-link custom-color-white pt-2" href="/log">Login/Registrati</a>
                <% } %>
            </span>
        </div>
    </nav>

    <div class="container my-5 p-4 border rounded shadow-sm bg-white">
        <form action="#">
            <div class="mb-3">
                <label for="nome" class="form-label">Nome</label>
                <input type="text" class="form-control" id="nome" name="nome" placeholder="Il tuo nome *" required>
            </div>

            <div class="mb-3">
                <label for="cognome" class="form-label">Cognome</label>
                <input type="text" class="form-control" id="cognome" name="cognome" placeholder="Il tuo cognome *" required>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" placeholder="La tua email *" required>
            </div>

            <div class="mb-3">
                <label for="numeroTelefono" class="form-label">Telefono</label>
                <input type="text" class="form-control" id="numeroTelefono" name="numeroTelefono" placeholder="Il tuo numero">
            </div>

            <div class="mb-3">
                <label for="richiesta" class="form-label">Richiesta</label>
                <textarea class="form-control" id="richiesta" name="richiesta" placeholder="Scrivi qualcosa *" required></textarea>
            </div>

            <p class="form-text">* sono campi richiesti</p>

            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>


    <footer class="custom-bg-color-2 py-4">
        <div class="container">
            <div class="row">
                <div class="col">
                    <a href="/auto" class="text-white">Auto</a>
                </div>
                <div class="col">
                    <a href="/furgoni" class="text-white">Furgoni</a>
                </div>
                <div class="col">
                    <a href="/moto" class="text-white">Moto</a>
                </div>
                <div class="col">
                    <a href="/chisiamo" class="text-white">Chi siamo</a>
                </div>
                <div class="col">
                    <a href="/privacy" class="text-white">Privacy e sicurezza</a>
                </div>
            </div>
        </div>
    </footer>

    <footer class="custom-bg-color-3 text-center py-3">
        <p class="color-white mb-0">© 2024 Renturin. Tutti i diritti riservati.</p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
